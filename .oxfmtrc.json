{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "sortImports": {
    "groups": [
      "side_effect",
      "builtin",
      "external",
      "type-external",
      ["internal", "subpath"],
      "type-internal",
      ["parent", "sibling", "index"],
      ["type-parent", "type-sibling", "type-index"],
      "style",
      "unknown"
    ],
    "newlinesBetween": true,
    "ignoreCase": true,
    "order": "asc"
  },
  "sortTailwindcss": {
    "functions": ["clsx", "cn", "cva", "tw"]
  },
  "sortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": ["*.gen.ts", "*.d.ts"]
}
