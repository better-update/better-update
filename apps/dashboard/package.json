{
  "name": "@better-update/dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "dev": "PORTLESS=1 portless dashboard.better-update vite dev",
    "dev:local": "vite dev",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "pretest:e2e": "bunx playwright install chromium",
    "preview": "vite preview",
    "test": "vitest run --project unit --project component",
    "test:all": "bun run test && bun run test:e2e",
    "test:e2e": "vitest run --project e2e --fileParallelism false --retry 2",
    "test:e2e:ci": "vitest run --project e2e --fileParallelism false --retry 1 --bail 1",
    "typegen:cf": "wrangler types"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.5",
    "@better-update/api": "workspace:*",
    "@better-update/api-client": "workspace:*",
    "@better-update/encoding": "workspace:*",
    "@better-update/expo-protocol": "workspace:*",
    "@better-update/react-hooks": "workspace:*",
    "@better-update/safe-json": "workspace:*",
    "@better-update/ui": "workspace:*",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-query": "^5.99.1",
    "@tanstack/react-router": "^1.168.23",
    "better-auth": "^1.6.5",
    "effect": "^3.21.1",
    "lucide-react": "^0.546.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-update/oxlint-config": "workspace:*",
    "@better-update/typescript-config": "workspace:*",
    "@tanstack/router-plugin": "^1.167.22",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  }
}
