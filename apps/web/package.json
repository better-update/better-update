{
  "name": "@better-update/web",
  "version": "0.34.0",
  "private": true,
  "description": "Better Update web app (accounts + console) on Cloudflare Workers",
  "homepage": "https://github.com/better-update/better-update",
  "repository": {
    "type": "git",
    "url": "https://github.com/better-update/better-update.git",
    "directory": "apps/web"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "dev": "PORTLESS=1 portless better-update vite dev",
    "dev:local": "vite dev",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "pretest:e2e": "bunx playwright install chromium",
    "preview": "vite preview",
    "test": "vitest run --project unit --project component",
    "test:all": "bun run test && bun run test:e2e",
    "test:e2e": "vitest run --project e2e-api --project e2e-browser --retry 2",
    "test:e2e:api": "vitest run --project e2e-api --retry 2",
    "test:e2e:browser": "vitest run --project e2e-browser --retry 2",
    "test:e2e:ci": "vitest run --project e2e-api --project e2e-browser --retry 1 --bail 1",
    "typegen:cf": "wrangler types"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.14",
    "@better-update/api": "workspace:*",
    "@better-update/api-client": "workspace:*",
    "@better-update/auth-client": "workspace:*",
    "@better-update/expo-protocol": "workspace:*",
    "@better-update/react-hooks": "workspace:*",
    "@better-update/safe-json": "workspace:*",
    "@better-update/ui": "workspace:*",
    "@cloudflare/vite-plugin": "^1.39.2",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@react-spring/web": "^10.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.11",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.19",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/zod-adapter": "^1.167.0",
    "better-auth": "^1.6.14",
    "cobe": "^2.0.1",
    "effect": "^3.21.2",
    "lucide-react": "^1.17.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-update/oxlint-config": "workspace:*",
    "@better-update/typescript-config": "workspace:*",
    "@rsbuild/core": "^2.0.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "agent-react-devtools": "^0.4.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "react-devtools-core": "^7.0.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.97.0"
  }
}
