{
  "name": "@better-update/server",
  "version": "0.3.1",
  "private": true,
  "description": "Better Update API server on Cloudflare Workers",
  "homepage": "https://github.com/better-update/better-update",
  "repository": {
    "type": "git",
    "url": "https://github.com/better-update/better-update.git",
    "directory": "apps/server"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "dev": "PORTLESS=1 portless api.better-update vite dev",
    "dev:local": "vite dev",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "preview": "vite preview",
    "test": "vitest run --project unit --coverage",
    "test:all": "bun run test && bun run test:integrations && bun run test:e2e",
    "test:e2e": "vitest run --project e2e --maxWorkers 1 --fileParallelism false",
    "test:integrations": "vitest run --project integration --maxWorkers 1 --fileParallelism false",
    "test:watch": "vitest --project unit",
    "typegen:cf": "wrangler types"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.6",
    "@better-update/api": "workspace:*",
    "@better-update/encoding": "workspace:*",
    "@better-update/safe-json": "workspace:*",
    "@effect/platform": "^0.96.0",
    "@noble/hashes": "^2.2.0",
    "better-auth": "^1.6.6",
    "effect": "^3.21.1",
    "es-toolkit": "^1.45.1",
    "s3mini": "^0.9.4",
    "structured-headers": "^2.0.2"
  },
  "devDependencies": {
    "@better-update/oxlint-config": "workspace:*",
    "@better-update/typescript-config": "workspace:*",
    "@cloudflare/vite-plugin": "^1.33.1",
    "@cloudflare/vitest-pool-workers": "^0.14.9",
    "@vitest/coverage-istanbul": "^4.1.5",
    "vite": "^8.0.9",
    "wrangler": "^4.84.1"
  }
}
