{
  "name": "@better-update/server",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "dev": "vite dev",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "preview": "vite preview",
    "test": "vitest run --project unit --coverage",
    "test:all": "vitest run",
    "test:e2e": "vitest run --project e2e",
    "test:integrations": "vitest run --project integration",
    "test:watch": "vitest --project unit",
    "typegen:cf": "wrangler types"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@better-auth/api-key": "^1.6.0",
    "@better-update/api": "workspace:*",
    "@better-update/bsdiff-wasm": "workspace:*",
    "@effect/platform": "^0.96.0",
    "better-auth": "^1.6.0",
    "effect": "^3.21.0",
    "structured-headers": "^2.0.2"
  },
  "devDependencies": {
    "@better-update/oxlint-config": "workspace:*",
    "@better-update/typescript-config": "workspace:*",
    "@cloudflare/vite-plugin": "^1.31.1",
    "@cloudflare/vitest-pool-workers": "^0.14.2",
    "@vitest/coverage-istanbul": "^4.1.3",
    "vite": "^8.0.7",
    "wrangler": "^4.81.0"
  }
}
