{
  "name": "@better-update/cli",
  "version": "0.36.2",
  "homepage": "https://github.com/better-update/better-update",
  "repository": {
    "type": "git",
    "url": "https://github.com/better-update/better-update.git",
    "directory": "apps/cli"
  },
  "bin": {
    "better-update": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "pretest:e2e": "tsdown",
    "pretest:slow": "tsdown",
    "test": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e --maxWorkers 1 --fileParallelism false",
    "test:interactive": "vitest run --project interactive --maxWorkers 1 --fileParallelism false",
    "test:slow": "vitest run --project slow --maxWorkers 1 --fileParallelism false",
    "test:watch": "vitest --project unit"
  },
  "dependencies": {
    "@better-update/bsdiff": "workspace:*",
    "@clack/prompts": "^1.5.1",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.107.0",
    "@expo/apple-utils": "^2.1.21",
    "@expo/config": "^56.0.9",
    "@expo/config-plugins": "~56.0.8",
    "@expo/pkcs12": "^0.5.1",
    "@expo/plist": "^0.7.0",
    "@expo/xcpretty": "^4.4.4",
    "@napi-rs/keyring": "^1.3.0",
    "bplist-parser": "^0.3.2",
    "chalk": "^5.6.2",
    "citty": "^0.2.2",
    "effect": "^3.21.3",
    "es-toolkit": "^1.47.0",
    "gradle-to-js": "^2.0.1",
    "ignore": "^7.0.5",
    "node-forge": "^1.4.0",
    "node-pty": "^1.1.0",
    "qrcode-terminal": "^0.12.0",
    "xcode": "^3.0.1"
  },
  "devDependencies": {
    "@better-update/api": "workspace:*",
    "@better-update/credentials-crypto": "workspace:*",
    "@better-update/encoding": "workspace:*",
    "@better-update/expo-codesign": "workspace:*",
    "@better-update/expo-protocol": "workspace:*",
    "@better-update/oxlint-config": "workspace:*",
    "@better-update/safe-json": "workspace:*",
    "@better-update/type-guards": "workspace:*",
    "@better-update/typescript-config": "workspace:*",
    "@types/node-forge": "^1.3.14",
    "@types/xcode": "^3.0.0",
    "tsdown": "^0.22.2"
  },
  "optionalDependencies": {
    "keychain": "^1.5.0"
  },
  "engines": {
    "node": ">=22"
  }
}
