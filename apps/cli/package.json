{
  "name": "@better-update/cli",
  "version": "0.8.1",
  "homepage": "https://github.com/better-update/better-update",
  "repository": {
    "type": "git",
    "url": "https://github.com/better-update/better-update.git",
    "directory": "apps/cli"
  },
  "bin": {
    "better-update": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "test": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e --maxWorkers 1 --fileParallelism false",
    "test:interactive": "vitest run --project interactive --maxWorkers 1 --fileParallelism false",
    "test:watch": "vitest --project unit"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@expo/apple-utils": "^2.1.21",
    "@expo/config": "^55.0.16",
    "@expo/pkcs12": "^0.4.2",
    "@expo/plist": "^0.5.3",
    "@expo/xcpretty": "^4.4.3",
    "bplist-parser": "^0.3.2",
    "citty": "^0.2.2",
    "effect": "^3.21.2",
    "es-toolkit": "^1.46.1",
    "gradle-to-js": "^2.0.1"
  },
  "devDependencies": {
    "@better-update/api": "workspace:*",
    "@better-update/encoding": "workspace:*",
    "@better-update/expo-protocol": "workspace:*",
    "@better-update/oxlint-config": "workspace:*",
    "@better-update/safe-json": "workspace:*",
    "@better-update/type-guards": "workspace:*",
    "@better-update/typescript-config": "workspace:*",
    "node-pty": "^1.1.0",
    "tsdown": "^0.21.10"
  },
  "optionalDependencies": {
    "keychain": "^1.5.0"
  },
  "engines": {
    "node": ">=22"
  }
}
