{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "cache": false
    },
    "lint:check": {
      "dependsOn": ["^lint:check"],
      "cache": false
    },
    "//#format": {
      "cache": false
    },
    "//#format:check": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:integrations": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "typegen:cf": {
      "dependsOn": ["^typegen:cf"],
      "cache": false
    }
  }
}
