{
  "name": "better-ota",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run lint:check format:check",
    "dev": "turbo run dev",
    "fix": "turbo run lint format",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "turbo run lint",
    "lint:check": "turbo run lint:check",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "lefthook": "^2.1.3",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "oxlint-tsgolint": "^0.16.0",
    "turbo": "^2.8.15",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.10"
}
