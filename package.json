{
  "name": "better-update",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run lint:check format:check",
    "dev": "turbo run dev",
    "fix": "turbo run lint format",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "turbo run lint",
    "lint:check": "turbo run lint:check",
    "prepare": "lefthook install --force",
    "test": "turbo run test",
    "test:all": "turbo run test test:integrations test:e2e",
    "test:e2e": "turbo run test:e2e",
    "test:integrations": "turbo run test:integrations",
    "typegen:cf": "turbo run typegen:cf"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-ssr-query": "^1.166.10",
    "@tanstack/react-start": "^1.167.16"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "^7.0.0-dev.20260403.1",
    "eslint-plugin-functional": "^9.0.4",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "turbo": "^2.9.3",
    "type-fest": "^5.5.0",
    "vitest": "^4.1.2"
  },
  "packageManager": "bun@1.3.10"
}
