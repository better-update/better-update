{
  "name": "better-update",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run lint:check format:check",
    "dev": "turbo run dev",
    "fix": "turbo run lint format",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "knip": "knip",
    "lint": "turbo run lint",
    "lint:check": "turbo run lint:check",
    "prepare": "lefthook install --force",
    "test": "turbo run test",
    "test:all": "bun run test && bun run test:integrations && bun run test:e2e",
    "test:e2e": "turbo run test:e2e --concurrency=1",
    "test:integrations": "turbo run test:integrations --concurrency=1",
    "typegen:cf": "turbo run typegen:cf"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.1",
    "@tanstack/react-router": "^1.168.23"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260419.1",
    "eslint-plugin-functional": "^9.0.4",
    "knip": "^6.4.1",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-plugin-eslint": "1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "turbo": "^2.9.6",
    "type-fest": "^5.6.0",
    "vitest": "^4.1.4"
  },
  "packageManager": "bun@1.3.10"
}
