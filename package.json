{
  "name": "better-update",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run lint:check format:check",
    "dev": "turbo run dev",
    "fix": "turbo run lint format",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "turbo run lint",
    "lint:check": "turbo run lint:check",
    "prepare": "lefthook install",
    "typegen:cf": "turbo run typegen:cf"
  },
  "dependencies": {
    "@tanstack/react-router-ssr-query": "^1.166.10"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260323.1",
    "eslint-plugin-functional": "^9.0.4",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "turbo": "^2.8.20",
    "type-fest": "^5.5.0"
  },
  "packageManager": "bun@1.3.10"
}
