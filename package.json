{
  "name": "better-update",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run lint:check format:check",
    "check:bsdiff": "node scripts/check-bsdiff-release.mjs",
    "d1:migrate": "turbo run d1:migrate",
    "dev": "turbo run dev",
    "dev:proxy": "portless proxy start",
    "dev:proxy:stop": "portless proxy stop",
    "dev:trust": "portless trust",
    "docs": "bun --filter @better-update/docs dev",
    "docs:build": "bun --filter @better-update/docs build",
    "docs:preview": "bun --filter @better-update/docs preview",
    "fix": "turbo run lint format",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "knip": "knip",
    "lint": "turbo run lint",
    "lint:check": "turbo run lint:check",
    "prepare": "lefthook install --force",
    "release:preview": "lerna version --conventional-commits --dry-run",
    "release:publish": "lerna publish from-package --yes",
    "release:version": "lerna version --conventional-commits --yes --no-push",
    "test": "turbo run test",
    "test:all": "bun run test && bun run test:integrations && bun run test:e2e",
    "test:e2e": "turbo run test:e2e",
    "test:integrations": "turbo run test:integrations",
    "typegen:cf": "turbo run typegen:cf",
    "verify": "node scripts/self-verify.mjs",
    "verify:e2e": "node scripts/self-verify.mjs --only=e2e"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@effect/language-service": "^0.86.2",
    "@effect/tsgo": "^0.14.0",
    "@effect/vitest": "^0.29.0",
    "@lerna-lite/cli": "^5.3.0",
    "@lerna-lite/publish": "^5.3.0",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@types/node": "^25.9.2",
    "@typescript/native-preview": "^7.0.0-dev.20260607.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint-plugin-functional": "^10.0.0",
    "knip": "^6.16.1",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-plugin-eslint": "1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "portless": "^0.14.0",
    "turbo": "^2.9.16",
    "type-fest": "^5.7.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "bun@1.3.13"
}
