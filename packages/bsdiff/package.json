{
  "name": "@better-update/bsdiff",
  "version": "0.2.4",
  "files": [
    "index.js",
    "index.d.ts",
    "src/magic.ts"
  ],
  "type": "commonjs",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./magic": "./src/magic.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "napi:prepublish": "napi prepublish -t npm",
    "test": "vitest run",
    "test:conformance": "node conformance/run-conformance.mjs"
  },
  "devDependencies": {
    "@better-update/oxlint-config": "workspace:*",
    "@better-update/typescript-config": "workspace:*",
    "@napi-rs/cli": "^3.7.0"
  },
  "optionalDependencies": {
    "@better-update/bsdiff-darwin-arm64": "0.2.1",
    "@better-update/bsdiff-darwin-x64": "0.2.1",
    "@better-update/bsdiff-linux-arm64-gnu": "0.2.1",
    "@better-update/bsdiff-linux-arm64-musl": "0.2.1",
    "@better-update/bsdiff-linux-x64-gnu": "0.2.1",
    "@better-update/bsdiff-linux-x64-musl": "0.2.1",
    "@better-update/bsdiff-win32-arm64-msvc": "0.2.1",
    "@better-update/bsdiff-win32-x64-msvc": "0.2.1"
  },
  "napi": {
    "binaryName": "bsdiff",
    "packageName": "@better-update/bsdiff",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">=22"
  }
}
