{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "extends": ["./base.json"],
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "react",
    "react-perf",
    "import",
    "jsx-a11y",
    "promise",
    "vitest",
    "jsdoc",
    "node"
  ],
  "rules": {
    "no-restricted-imports": [
      "warn",
      {
        "paths": [
          {
            "name": "react",
            "importNames": ["useEffect", "useLayoutEffect"],
            "message": "Do not use useEffect/useLayoutEffect. Use useMountEffect for mount-only side effects, XState actors for stateful side effects, or TanStack Router loaders for data fetching."
          }
        ]
      }
    ],

    "react/jsx-max-depth": ["warn", { "max": 6 }],
    "react/react-in-jsx-scope": "off",
    "react/jsx-filename-extension": "off",
    "react/no-multi-comp": "off"
  }
}
